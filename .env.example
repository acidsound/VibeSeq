# Copy this file to .env and replace the empty values locally.
# Never commit the populated .env file. Existing process variables take
# precedence over this file when scripts/run-inference.* starts the server.

# Hugging Face token with access to the accepted Stable Audio 3 and
# MuScriptor model terms.
HF_TOKEN=

# Reserved only. The current Colab notebook does not consume this value, and
# Colab Enterprise automation uses Google ADC rather than this generic name.
COLAB_API_KEY=

# Optional local diagnostic/fallback mode. When enabled, both Stable Audio 3
# and MuScriptor use CPU routes even if Metal or CUDA is available.
# This is valid only with VIBESEQ_TARGET=local.
VIBESEQ_FORCE_CPU=0
